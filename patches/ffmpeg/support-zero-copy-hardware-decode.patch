+static void oh_decode_clear_dovi(OHCodecDecContext *s)
+{
+    for (int i = 0; i < s->nb_dovi_frames; i++) {
+        av_buffer_unref(&s->dovi_frames[i].rpu);
+        av_buffer_unref(&s->dovi_frames[i].metadata);
+    }
+    s->nb_dovi_frames = 0;
+}
