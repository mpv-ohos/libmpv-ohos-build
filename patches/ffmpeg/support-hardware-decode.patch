+static enum AVPixelFormat oh_sw_format_from_native_format(OH_NativeBuffer_Format format)
+{
+    switch (format) {
+    case NATIVEBUFFER_PIXEL_FMT_YCBCR_P010:
+    case NATIVEBUFFER_PIXEL_FMT_YCRCB_P010:
+        return AV_PIX_FMT_P010;
+    case NATIVEBUFFER_PIXEL_FMT_YCBCR_420_SP:
+        return AV_PIX_FMT_NV12;
+    case NATIVEBUFFER_PIXEL_FMT_YCRCB_420_SP:
+        return AV_PIX_FMT_NV21;
+    default:
+        return AV_PIX_FMT_NONE;
+    }
+}
+
+static enum AVPixelFormat oh_decode_resolve_sw_format(AVCodecContext *avctx,
+                                                      OH_AVBuffer *buffer,
+                                                      OH_NativeBuffer_Format *native_format_out)
+{
+    OH_NativeBuffer *native_buffer = OH_AVBuffer_GetNativeBuffer(buffer);
+    if (!native_buffer)
+        return avctx->sw_pix_fmt;
+
+    OH_NativeBuffer_Config config = {0};
+    OH_NativeBuffer_GetConfig(native_buffer, &config);
+    OH_NativeBuffer_Unreference(native_buffer);
+
+    if (native_format_out)
+        *native_format_out = config.format;
+
+    enum AVPixelFormat sw_format = oh_sw_format_from_native_format(config.format);
+    return sw_format == AV_PIX_FMT_NONE ? avctx->sw_pix_fmt : sw_format;
+}
+
+static AVOHCodecDeviceContext *oh_decode_device_hwctx(AVCodecContext *avctx)
+{
+    if (!avctx->hw_device_ctx)
+        return NULL;
+
+    AVHWDeviceContext *device_ctx = (AVHWDeviceContext *)avctx->hw_device_ctx->data;
+    if (!device_ctx || device_ctx->type != AV_HWDEVICE_TYPE_OHCODEC)
+        return NULL;
+
+    return device_ctx->hwctx;
+}
+
+static uint64_t oh_decode_output_generation(AVCodecContext *avctx)
+{
+    AVOHCodecDeviceContext *dev = oh_decode_device_hwctx(avctx);
+    return dev ? dev->output_generation : 0;
+}
+
+static void oh_decode_invalidate_outputs(AVCodecContext *avctx)
+{
+    AVOHCodecDeviceContext *dev = oh_decode_device_hwctx(avctx);
+    if (dev)
+        dev->output_generation++;
+}
